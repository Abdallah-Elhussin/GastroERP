{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=GastroErpDb;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Secret": "super-secret-key-that-should-be-very-long-for-hmac-sha256",
    "Key": "super-secret-key-that-should-be-very-long-for-hmac-sha256",
    "Issuer": "GastroErp",
    "Audience": "GastroErpClient",
    "ExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7
  },
  "Cors": {
    "AllowedOrigins": [
      "https://example.com"
    ]
  },
  "RateLimiting": {
    "FixedWindowSeconds": 10,
    "FixedPermitLimit": 100,
    "QueueLimit": 2,
    "SlidingWindowSeconds": 30,
    "SlidingPermitLimit": 100,
    "SegmentsPerWindow": 3
  },
  "RequestLimits": {
    "MaxRequestBodySize": 10485760
  }
}
